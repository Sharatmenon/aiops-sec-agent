# aiops-sec-agent — Environment Variables
# Copy to .env and fill in your keys. Never commit .env to git.

# Required
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Optional: LangSmith tracing (free at smith.langchain.com)
LANGCHAIN_API_KEY=ls__YOUR_KEY_HERE
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=aiops-sec-agent

# MCP mode (requires: docker compose up)
USE_MCP_TOOLS=false
KUBECTL_MCP_URL=http://localhost:8001
ARGOCD_MCP_URL=http://localhost:8002
LOGQUERY_MCP_URL=http://localhost:8003
